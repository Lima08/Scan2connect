# Local Docker — docker-compose.yml (development / smoke test)
# For production (Portainer + Traefik), use .env.prod.example with docker-compose.prod.yml
# See docs/deploy-portainer.md

# Required
ADMIN_PASSWORD=change-me
BASE_URL=http://localhost:3000
SESSION_SECRET=troque-por-um-segredo-aleatorio-com-32-caracteres-ou-mais

# Fixed path inside the container (do not change)
DB_PATH=/data/data.db

# Optional — host port mapping (default: 3000)
PORT=3000

# Optional — image reference when pulling from GHCR instead of build
# GITHUB_OWNER=lima08
# IMAGE_TAG=latest
