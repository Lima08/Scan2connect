# Production — Portainer stack environment variables
# Used with docker-compose.prod.yml
# Guide: docs/deploy-portainer.md

# Required — FULL hostname (not just "scan-gdg")
DOMAIN=scan-gdg.limadesenvolvimento.com
ADMIN_PASSWORD=change-me-strong-password
SESSION_SECRET=change-me-random-secret-at-least-32-characters

# DNS reminder (Hostinger): create A record with Name=scan-gdg → server IP
# Do NOT put "scan-gdg" here — use the full DOMAIN above

# Optional — image from GHCR (see https://github.com/Lima08/Scan2connect/pkgs/container/scan2connect)
GITHUB_OWNER=lima08
IMAGE_TAG=v1.0.0

# Optional — localhost debug port on the server (default: 13087, bind 127.0.0.1 only)
HOST_BIND_PORT=13087

# Optional
TZ=America/Sao_Paulo
