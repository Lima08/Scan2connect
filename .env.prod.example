# Copy to Portainer stack environment variables (or .env on the server).
# Used with docker-compose.prod.yml

# Required
DOMAIN=limadesenvolvimento.com
ADMIN_PASSWORD=change-me-strong-password
SESSION_SECRET=change-me-random-secret-at-least-32-characters

# Optional — image from GHCR
GITHUB_OWNER=lima08
IMAGE_TAG=latest

# Optional — localhost debug port on the server (default: 13087)
HOST_BIND_PORT=13087

# Optional
TZ=America/Sao_Paulo
